# nginx — music.arturlun.ru
# Установка: docs/deployment.md

upstream php_fpm {
    server unix:/run/php/php8.4-fpm.sock;
}

server {
    listen 80;
    server_name music.arturlun.ru;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name music.arturlun.ru;

    ssl_certificate     /etc/letsencrypt/live/music.arturlun.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/music.arturlun.ru/privkey.pem;

    root /var/www/om-player/backend/public;
    index index.php;

    client_max_body_size 64M;

    # Аудио через PHP — проверка подписи URL (защита от прямого скачивания)
    location ^~ /media/audio/ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $realpath_root/index.php;
        fastcgi_param REQUEST_URI $request_uri;
        fastcgi_pass php_fpm;
    }

    location /media/covers/ {
        alias /var/www/om-player/backend/public/media/covers/;
        add_header Access-Control-Allow-Origin "https://arturlun.ru";
        expires 7d;
    }

    location ~* \.(js|css|svg|woff2?|ico|png|webp)$ {
        try_files $uri =404;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    location / {
        try_files $uri /index.php$is_args$args;
    }

    location ~ ^/index\.php(/|$) {
        fastcgi_pass php_fpm;
        fastcgi_split_path_info ^(.+\.php)(/.*)$;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $realpath_root$fastcgi_script_name;
        fastcgi_param DOCUMENT_ROOT $realpath_root;
        internal;
    }

    location ~ \.php$ {
        return 404;
    }
}

# /admin защищён Symfony Security (ADMIN_USERNAME / ADMIN_PASSWORD в backend/.env)

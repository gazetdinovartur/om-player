<!DOCTYPE html>
<html lang="ru" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="turbo-cache-control" content="cache">
    <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">
    <link rel="icon" href="{{ asset('favicon-32.png') }}" type="image/png" sizes="32x32">
    <link rel="apple-touch-icon" href="{{ asset('apple-touch-icon.png') }}">
    <link rel="manifest" href="{{ asset('manifest.json') }}">
    <meta name="theme-color" content="#4a7c59">
    <title>{% block title %}OmPlayer{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet"></noscript>
    <link rel="stylesheet" href="{{ asset('css/site.css') }}">
    <script src="{{ asset('js/om-audio-root.js') }}"></script>
    <script type="module" src="{{ asset('js/turbo.es2017-esm.js') }}"></script>
    {% block head %}{% endblock %}
</head>
<body>
    <div class="site-bg" aria-hidden="true" data-turbo-permanent>
        <div class="site-bg__orb site-bg__orb--1"></div>
        <div class="site-bg__orb site-bg__orb--2"></div>
        <div class="site-bg__orb site-bg__orb--3"></div>
        <div class="site-bg__noise"></div>
    </div>

    <header class="site-header" id="site-header" data-turbo-permanent>
        <div class="site-header__inner">
            <a class="site-logo" href="{{ path('web_home') }}" data-turbo-preload>
                <span class="site-logo__mark" aria-hidden="true">
                    <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13 3a10 10 0 0 1 0 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.45"/>
                        <path d="M13 7a6 6 0 0 1 0 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        <circle cx="13" cy="13" r="2" fill="currentColor"/>
                    </svg>
                </span>
                <span class="site-logo__text">Om<span class="site-logo__accent">Player</span></span>
            </a>
            <nav class="site-nav site-nav--desktop" aria-label="Основная навигация">
                <a href="{{ path('web_music_catalog') }}" data-turbo-preload>Альбомы</a>
                <a href="{{ path('web_music_favorites') }}" data-turbo-preload>Любимое</a>
                <a href="{{ path('web_about') }}" data-turbo-preload>О проекте</a>
                <a href="{{ path('admin') }}" data-turbo="false">Управление</a>
            </nav>
            <div class="site-header__actions">
                <button type="button" class="theme-toggle" id="theme-toggle" aria-label="Переключить тему">
                    <svg class="theme-toggle__icon theme-toggle__icon--light" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
                    <svg class="theme-toggle__icon theme-toggle__icon--dark" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                </button>
                <button
                    type="button"
                    class="site-menu-toggle"
                    id="site-menu-toggle"
                    aria-expanded="false"
                    aria-controls="site-mobile-menu"
                    aria-label="Открыть меню"
                >
                    <svg class="site-menu-toggle__icon site-menu-toggle__icon--open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round"/>
                    </svg>
                    <svg class="site-menu-toggle__icon site-menu-toggle__icon--close" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
                        <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round"/>
                    </svg>
                </button>
            </div>
        </div>
        <div class="site-mobile-menu" id="site-mobile-menu" hidden>
            <div class="site-mobile-menu__backdrop" tabindex="-1" aria-hidden="true"></div>
            <div class="site-mobile-menu__panel">
                <nav class="site-mobile-nav" aria-label="Мобильная навигация">
                    <a href="{{ path('web_music_catalog') }}" data-turbo-preload>Альбомы</a>
                <a href="{{ path('web_music_favorites') }}" data-turbo-preload>Любимое</a>
                    <a href="{{ path('web_about') }}" data-turbo-preload>О проекте</a>
                    <a href="{{ path('admin') }}" data-turbo="false">Управление</a>
                </nav>
            </div>
        </div>
    </header>

    <main class="site-main">
        {% block body %}{% endblock %}
    </main>

    {% include 'partials/footer.html.twig' %}

    <div class="mini-player-shell" id="om-persistent-player" data-turbo-permanent>
        <om-player
            mode="mini"
            id="om-global"
            data-turbo-permanent
            api-base="{{ app.request.schemeAndHttpHost }}/api/v1"
            theme="light"
        ></om-player>
    </div>

    <script type="module" src="{{ asset('build/player/om-player.iife.js') }}" data-turbo-eval="false"></script>
    <script src="{{ asset('js/theme.js') }}" data-turbo-eval="false"></script>
    <script src="{{ asset('js/site-nav.js') }}" defer data-turbo-eval="false"></script>
    <script src="{{ asset('js/om-hero-viz.js') }}" defer data-turbo-eval="false"></script>
    <script src="{{ asset('js/om-favorites.js') }}" defer data-turbo-eval="false"></script>
    <script src="{{ asset('js/player-bridge.js') }}" defer data-turbo-eval="false"></script>
    {% block scripts %}{% endblock %}
</body>
</html>

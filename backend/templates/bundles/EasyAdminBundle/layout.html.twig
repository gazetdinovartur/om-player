{% extends '@!EasyAdmin/layout.html.twig' %}

{% macro om_logo(compact) %}
    <span class="ea-brand">
        <span class="ea-brand__mark" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13 3a10 10 0 0 1 0 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.45"/>
                <path d="M13 7a6 6 0 0 1 0 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="13" cy="13" r="2" fill="currentColor"/>
            </svg>
        </span>
        <span class="ea-brand__text">Om<span class="ea-brand__accent">Player</span></span>
    </span>
{% endmacro %}

{% block head_metas %}
    {{ parent() }}
    <script type="module" src="{{ asset('js/turbo.es2017-esm.js') }}"></script>
{% endblock %}

{% block head_favicon %}
    <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">
    <link rel="icon" href="{{ asset('favicon-32.png') }}" type="image/png" sizes="32x32">
    <link rel="apple-touch-icon" href="{{ asset('apple-touch-icon.png') }}">
{% endblock %}

{% block body_attr %}data-turbo="true"{% endblock %}

{% block header_logo %}
    <a class="logo logo--om" title="OmPlayer" href="{{ path(ea.dashboardRouteName) }}">
        <span class="logo-custom">{{ _self.om_logo(false) }}</span>
        <span class="logo-compact">{{ _self.om_logo(true) }}</span>
    </a>
{% endblock %}

{% block responsive_header_logo %}
    <a class="responsive-logo logo--om" title="OmPlayer" href="{{ path(ea.dashboardRouteName) }}">
        {{ _self.om_logo(false) }}
    </a>
{% endblock %}

{% block configured_body_contents %}
    {{ parent() }}
{% endblock %}

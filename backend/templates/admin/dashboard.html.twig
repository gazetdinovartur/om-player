{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Панель управления{% endblock %}

{% block main %}
<div class="admin-home">
    <p class="admin-home__lead">
        Управляйте каталогом OmPlayer: загружайте треки с автоматическими метаданными,
        настраивайте альбомы и плейлисты для сайта и плеера.
    </p>

    <a class="admin-home__card admin-home__card--featured" href="{{ path('admin_upload_track') }}">
        <span class="admin-home__card-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 16V8m0 0l-3 3m3-3l3 3" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
            </svg>
        </span>
        <span class="admin-home__card-body">
            <span class="admin-home__card-title">Загрузить трек</span>
            <span class="admin-home__card-desc">Перетащите MP3 или M4A — метаданные и обложка подтянутся автоматически</span>
        </span>
        <span class="admin-home__card-arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M7.5 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </span>
    </a>

    <div class="admin-home__cards">
        <div class="admin-home__row admin-home__row--top">
            <a class="admin-home__card" href="{{ path('admin_album_index') }}">
            <span class="admin-home__card-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                </svg>
            </span>
            <span class="admin-home__card-body">
                <span class="admin-home__card-title">Альбомы</span>
                <span class="admin-home__card-desc">Обложки, порядок, публикация</span>
            </span>
        </a>

        <a class="admin-home__card" href="{{ path('admin_track_index') }}">
            <span class="admin-home__card-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M9 18V6l12-2v12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="6" cy="18" r="3" stroke="currentColor" stroke-width="1.5"/>
                    <circle cx="18" cy="16" r="3" stroke="currentColor" stroke-width="1.5"/>
                </svg>
            </span>
            <span class="admin-home__card-body">
                <span class="admin-home__card-title">Треки</span>
                <span class="admin-home__card-desc">Каталог, slug, статус публикации</span>
            </span>
        </a>

        <a class="admin-home__card" href="{{ path('admin_playlist_index') }}">
            <span class="admin-home__card-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M8 6h13M8 12h13M8 18h13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    <path d="M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
            </span>
            <span class="admin-home__card-body">
                <span class="admin-home__card-title">Плейлисты</span>
                <span class="admin-home__card-desc">Подборки для сайта и API</span>
            </span>
        </a>
        </div>

        <div class="admin-home__row admin-home__row--bottom">
            <a class="admin-home__card" href="{{ path('admin_artist_index') }}">
            <span class="admin-home__card-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M4 20c0-3.314 3.582-6 8-6s8 2.686 8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
            </span>
            <span class="admin-home__card-body">
                <span class="admin-home__card-title">Артисты</span>
                <span class="admin-home__card-desc">Исполнители и привязка к трекам</span>
            </span>
        </a>

        <a class="admin-home__card" href="{{ path('web_home') }}">
            <span class="admin-home__card-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                    <path d="M3 10.5L12 4l9 6.5V19a1 1 0 01-1 1h-5v-6H9v6H4a1 1 0 01-1-1v-8.5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
            </span>
            <span class="admin-home__card-body">
                <span class="admin-home__card-title">Открыть сайт</span>
                <span class="admin-home__card-desc">Посмотреть, как выглядит каталог для слушателей</span>
            </span>
        </a>
        </div>
    </div>
</div>
{% endblock %}

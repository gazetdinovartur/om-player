<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Вход — OmPlayer Admin</title>
    <link rel="icon" href="{{ asset('favicon.svg') }}" type="image/svg+xml">
    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">
    <style>
        body { min-height: 100vh; display: grid; place-items: center; background: #0f1410; color: #e8e4dc; font-family: Montserrat, system-ui, sans-serif; margin: 0; }
        .login { width: min(100% - 2rem, 380px); padding: 2rem; border-radius: 16px; background: #171c18; border: 1px solid rgba(255,255,255,.08); }
        .login h1 { margin: 0 0 .5rem; font-size: 1.35rem; font-weight: 600; }
        .login p { margin: 0 0 1.5rem; color: #9a9488; font-size: .9rem; }
        .login label { display: block; margin-bottom: .35rem; font-size: .85rem; color: #b8b2a6; }
        .login input { width: 100%; box-sizing: border-box; padding: .75rem .85rem; margin-bottom: 1rem; border-radius: 10px; border: 1px solid rgba(255,255,255,.12); background: #0f1410; color: inherit; font: inherit; }
        .login button { width: 100%; padding: .8rem; border: 0; border-radius: 10px; background: #4a7c59; color: #fff; font: inherit; font-weight: 600; cursor: pointer; }
        .login button:hover { background: #3d6649; }
        .login .error { margin-bottom: 1rem; padding: .65rem .85rem; border-radius: 8px; background: rgba(180,60,60,.15); color: #f0a8a8; font-size: .85rem; }
    </style>
</head>
<body>
    <form class="login" method="post">
        <h1>OmPlayer</h1>
        <p>Вход в панель управления</p>

        {% if error %}
            <div class="error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <label for="username">Логин</label>
        <input id="username" name="_username" value="{{ last_username }}" autocomplete="username" required autofocus>

        <label for="password">Пароль</label>
        <input id="password" name="_password" type="password" autocomplete="current-password" required>

        <button type="submit">Войти</button>
    </form>
</body>
</html>

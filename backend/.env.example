# Единый файл окружения OmPlayer.
# Создать: bash scripts/init-env.sh

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_run_scripts_init_env_sh
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://127.0.0.1:8000
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://om:om@127.0.0.1:3306/om_player?serverVersion=8.4&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> om-player ###
# Имя артиста по умолчанию при импорте/загрузке, если в ID3 нет artist
JMO_DEFAULT_ARTIST_NAME="Артур Лун"

# Путь к папке альбома для `make seed-album` / app:import-album (без --path). Опционально.
# JMO_SEED_ALBUM_PATH=/path/to/album

# Абсолютный URL сайта для обложек в API. Локально оставьте пустым (relative /media/...).
# На prod: https://music.arturlun.ru (нужен для lock screen iOS)
MEDIA_BASE_URL=

# Защита аудио: подписанные URL с TTL. Прямой доступ к /media/audio/... без sig= → 403.
# Локально можно отключить: MEDIA_STREAM_PROTECT=0
MEDIA_STREAM_PROTECT=1
MEDIA_STREAM_TTL=14400

# Admin — plain-text пароль (как при входе на /admin/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_or_set_your_password
###< om-player ###

###> docker mysql ###
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=om_player
MYSQL_USER=om
MYSQL_PASSWORD=om
###< docker mysql ###
